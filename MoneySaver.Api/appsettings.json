{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,9433;Database=MoneySaver;User Id=sa;Password=Strong@Password;Integrated Security=False;TrustServerCertificate=True;MultipleActiveResultSets=true"
    //"DefaultConnection": "Server=host.docker.internal,3433;Database=MoneySaver;User Id=sa;Password=Pass@word;Integrated Security=False;MultipleActiveResultSets=true"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.MariaDB" ],
    "MinimumLevel": "Warning",
    "WriteTo": [
      {
        "Name": "MariaDB",
        "Args": {
          "connectionString": "server=localhost;Port=9306;uid=root;pwd=mysecretpass;database=db_logging",
          //"connectionString": "server=host.docker.internal;Port=3306;uid=root;pwd=SecretPass;database=db_logging",
          "autoCreateTable": true,
          "tableName": "logging",
          "batchPostingLimit": 1000,
          "storeTimestampInUtc": true,
          "options": {
            "PropertiesToColumnsMapping": {
              "Exception": "Exception",
              "Level": "Level",
              "Message": "Message",
              "MessageTemplate": "MessageTemplate",
              "Timestamp": "Timestamp",
              "ActionId": "ActionId",
              "Application": "Application",
              "SourceContext": "SourceContext"
            },
            "TimestampInUtc": true,
            "ExcludePropertiesWithDedicatedColumn": false,
            "EnumsAsInts": true,
            "LogRecordsCleanupFrequency": "0.02:00:00",
            "LogRecordsExpiration": "31.00:00:00"
          }
        }
      }
    ],
    "Properties": {
      "Application": "MoneySaver API"
    }
  },
  "ApplicationSettings": {
    "Secret": ""
  }
}
